# =============================================================================
# Multi-Agent Research Assistant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Only GROQ_API_KEY is required. All other settings have sensible defaults.
# =============================================================================

# ─── Required ────────────────────────────────────────────────────────────────

# Groq API key — get one free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─── LLM Configuration (optional) ───────────────────────────────────────────

# Groq model to use (default: llama-3.3-70b-versatile)
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768
# GROQ_MODEL=llama-3.3-70b-versatile

# Sampling temperature — lower = more deterministic (default: 0.1)
# GROQ_TEMPERATURE=0.1

# Maximum tokens per LLM response (default: 4096)
# GROQ_MAX_TOKENS=4096

# Retry attempts for failed API requests (default: 3)
# GROQ_MAX_RETRIES=3

# Request timeout in seconds (default: 60)
# GROQ_TIMEOUT=60

# ─── Workflow Configuration (optional) ───────────────────────────────────────

# Maximum supervisor decision iterations before forced finish (default: 6)
# MAX_ITERATIONS=6

# Maximum ReAct tool-call iterations per search agent run (default: 4)
# MAX_TOOL_ITERATIONS=4

# ─── Search Configuration (optional) ─────────────────────────────────────────

# Web search results per query (default: 6)
# SEARCH_MAX_RESULTS=6

# News search results per query (default: 5)
# NEWS_MAX_RESULTS=5

# ─── Output Configuration (optional) ─────────────────────────────────────────

# Directory for markdown research exports (default: research_outputs)
# OUTPUT_DIR=research_outputs

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO
